@page "/Alisson"
@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager Nav

<div class="layout-root">

    <div class="particles-container" aria-hidden="true">
        @foreach (var p in particles)
        {
            <div class="particle @p.Type"
                 style="
                    left: @(p.X)%;
                    width: @(p.Size)px;
                    height: @(p.Size)px;
                    animation-duration: @(p.Duration)s;
                    animation-delay: @(p.Delay)s;
                    --drift: @(p.Drift)px;
                    opacity: 0;
                 ">
            </div>
        }
    </div>


    <header class="hk-nav @(isScrolled ? "scrolled" : "") @(menuOpen ? "menu-open" : "")">
        <nav class="nav-inner">
            <a href="/" class="nav-logo" id="nav-logo" title="Voltar aos Portfólios">
                <span class="nav-logo-icon">⚔</span>
                <span class="nav-logo-text">Alisson <span class="soul-accent">Caio</span></span>
                <span class="logo-tooltip text-silver">⬅ Voltar</span>
            </a>

            <ul class="nav-links" id="nav-links">
                <li><a href="javascript:void(0)" @onclick='() => ChangePage("Home")'     class="nav-link @(activePage=="Home"?"active":"")"     id="nav-home">Início</a></li>
                <li><a href="javascript:void(0)" @onclick='() => ChangePage("About")'    class="nav-link @(activePage=="About"?"active":"")"    id="nav-about">Sobre</a></li>
                <li><a href="javascript:void(0)" @onclick='() => ChangePage("Skills")'   class="nav-link @(activePage=="Skills"?"active":"")"   id="nav-skills">Habilidades</a></li>
                <li><a href="javascript:void(0)" @onclick='() => ChangePage("Projects")' class="nav-link @(activePage=="Projects"?"active":"")" id="nav-projects">Projetos</a></li>
                <li><a href="javascript:void(0)" @onclick='() => ChangePage("Contact")'  class="nav-link @(activePage=="Contact"?"active":"")"  id="nav-contact">Contato</a></li>
            </ul>


            <div class="nav-hud-right">
                <div class="hud-vessels" aria-label="Soul vessels">
                    <div class="hud-vessel filled"></div>
                    <div class="hud-vessel filled"></div>
                    <div class="hud-vessel filled"></div>
                    <div class="hud-vessel filled"></div>
                    <div class="hud-vessel"></div>
                </div>
                <div class="hud-geo">
                    <div class="hud-geo-icon"></div>
                    <span>2025</span>
                </div>
            </div>

            <button class="nav-toggle" @onclick="ToggleMenu" id="nav-toggle" aria-label="Abrir menu">
                <span class="toggle-line @(menuOpen ? "open" : "")"></span>
                <span class="toggle-line @(menuOpen ? "open" : "")"></span>
                <span class="toggle-line @(menuOpen ? "open" : "")"></span>
            </button>
        </nav>

        @if (menuOpen)
        {
            <div class="mobile-menu" id="mobile-menu">
                <ul>
                    <li><a href="javascript:void(0)" @onclick='() => ChangePage("Home")'     @onclick="CloseMenu" class="mobile-link">Início</a></li>
                    <li><a href="javascript:void(0)" @onclick='() => ChangePage("About")'    @onclick="CloseMenu" class="mobile-link">Sobre</a></li>
                    <li><a href="javascript:void(0)" @onclick='() => ChangePage("Skills")'   @onclick="CloseMenu" class="mobile-link">Habilidades</a></li>
                    <li><a href="javascript:void(0)" @onclick='() => ChangePage("Projects")' @onclick="CloseMenu" class="mobile-link">Projetos</a></li>
                    <li><a href="javascript:void(0)" @onclick='() => ChangePage("Contact")'  @onclick="CloseMenu" class="mobile-link">Contato</a></li>
                </ul>
            </div>
        }
    </header>

    <main class="main-content">
        <article>

            @if (activePage == "Home")
            {

                <section class="hero" id="hero">
                    <div class="hero-bg">
                        <img src="images/hero-bg.png" alt="" aria-hidden="true" class="hero-bg-img" />
                        <div class="hero-bg-overlay"></div>
                    </div>
                    <div class="hero-scanlines" aria-hidden="true"></div>

                    <div class="hero-content">

                        <div class="knight-assembly">
                            <div class="nail-slash" aria-hidden="true">
                                <div class="slash-trail"></div>
                                <div class="slash-trail t2"></div>
                                <div class="slash-trail t3"></div>
                            </div>
                            <div class="knight-container">
                                <img src="images/knight.png" alt="The Knight" class="knight-img" id="hero-knight" />
                                <div class="knight-aura"></div>
                                <div class="knight-shadow"></div>
                            </div>
                        </div>


                        <div class="hero-text">
                            <p class="hero-eyebrow">
                                <span class="eyebrow-line"></span>
                                Desenvolvedor Front-End
                                <span class="eyebrow-line"></span>
                            </p>
                            <h1 class="hero-title">
                                Alisson <span class="title-soul">Caio</span>
                            </h1>
                            <p class="hero-subtitle">
                                Explorando as profundezas do código como o Knight percorre Hallownest —<br />
                                com propósito, precisão e elegância.
                            </p>

                            <div class="soul-vessels" aria-hidden="true">
                                <div class="vessel active"></div>
                                <div class="vessel active"></div>
                                <div class="vessel active"></div>
                                <div class="vessel active"></div>
                                <div class="vessel"></div>
                            </div>

                            <div class="hero-ctas">
                                <a href="javascript:void(0)" @onclick='() => ChangePage("Projects")' class="btn-soul" id="hero-cta-projects">
                                    <span>⚔</span> Ver Projetos
                                </a>
                                <a href="javascript:void(0)" @onclick='() => ChangePage("About")' class="btn-essence" id="hero-cta-about">
                                    <span>📜</span> Sobre Mim
                                </a>
                            </div>

                            <div class="scroll-hint" id="hero-scroll-hint">
                                <div class="scroll-nail"></div>
                                <span>Descer</span>
                            </div>
                        </div>
                    </div>
                </section>


                <section class="stats-section" id="stats">
                    <div class="stats-container">
                        <div class="stat-item gothic-card" id="stat-projects">
                            <div class="card-corner tl"></div><div class="card-corner tr"></div>
                            <div class="card-corner bl"></div><div class="card-corner br"></div>
                            <span class="stat-icon text-soul">⚡</span>
                            <div class="stat-number text-pale">10+</div>
                            <div class="stat-label">Projetos Concluídos</div>
                        </div>
                        <div class="stat-divider" aria-hidden="true">✦</div>
                        <div class="stat-item gothic-card" id="stat-skills">
                            <div class="card-corner tl"></div><div class="card-corner tr"></div>
                            <div class="card-corner bl"></div><div class="card-corner br"></div>
                            <span class="stat-icon text-essence">✦</span>
                            <div class="stat-number text-pale">15+</div>
                            <div class="stat-label">Tecnologias</div>
                        </div>
                        <div class="stat-divider" aria-hidden="true">✦</div>
                        <div class="stat-item gothic-card" id="stat-experience">
                            <div class="card-corner tl"></div><div class="card-corner tr"></div>
                            <div class="card-corner bl"></div><div class="card-corner br"></div>
                            <span class="stat-icon text-geo">◆</span>
                            <div class="stat-number text-pale">3+</div>
                            <div class="stat-label">Anos de Experiência</div>
                        </div>
                        <div class="stat-divider" aria-hidden="true">✦</div>
                        <div class="stat-item gothic-card" id="stat-passion">
                            <div class="card-corner tl"></div><div class="card-corner tr"></div>
                            <div class="card-corner bl"></div><div class="card-corner br"></div>
                            <span class="stat-icon text-infect">♥</span>
                            <div class="stat-number text-pale">∞</div>
                            <div class="stat-label">Paixão pelo Código</div>
                        </div>
                    </div>
                </section>


                <section class="featured-section" id="featured-skills">
                    <div class="section-container">
                        <div class="section-header">
                            <h2 class="text-pale">Charms Equipados</h2>
                            <div class="section-divider">
                                <span class="section-subtitle">habilidades em destaque</span>
                            </div>
                        </div>

                        <div class="charms-preview">
                            @foreach (var charm in FeaturedCharms)
                            {
                                <div class="charm-preview gothic-card" id="charm-@charm.Id">
                                    <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                    <div class="card-corner bl"></div><div class="card-corner br"></div>
                                    <span class="charm-icon" style="color: @charm.Color; filter: drop-shadow(0 0 8px @charm.Color)">@charm.Icon</span>
                                    <span class="charm-name text-pale">@charm.Name</span>
                                    <div class="charm-level">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            <span class="level-dot @(i < charm.Level ? "filled" : "")" style="--dot-color: @charm.Color"></span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="text-center mt-lg">
                            <a href="javascript:void(0)" @onclick='() => ChangePage("Skills")' class="btn-soul" id="hero-all-skills">
                                Ver Todos os Charms ✦
                            </a>
                        </div>
                    </div>
                </section>
            }

            else if (activePage == "About")
            {
                <div class="page-container">
                    <div class="section-header">
                        <h1 class="text-pale">O Viajante</h1>
                        <div class="section-divider">
                            <span class="section-subtitle">sobre mim</span>
                        </div>
                    </div>

                    <div class="about-grid">

                        <div class="about-left" id="about-profile">
                            <div class="profile-frame">
                                <div class="profile-placeholder">
                                    <div class="profile-initials text-soul">AC</div>
                                    <div class="profile-glow"></div>
                                </div>
                                <div class="profile-frame-corners">
                                    <span class="frame-corner tl"></span>
                                    <span class="frame-corner tr"></span>
                                    <span class="frame-corner bl"></span>
                                    <span class="frame-corner br"></span>
                                </div>
                            </div>

                            <div class="info-card gothic-card" id="about-info-card">
                                <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                <div class="card-corner bl"></div><div class="card-corner br"></div>
                                <div class="info-row">
                                    <span class="info-icon text-soul">📍</span>
                                    <span class="text-silver">Brasil</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon text-essence">💼</span>
                                    <span class="text-silver">Desenvolvedor Front-End</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon text-geo">🎓</span>
                                    <span class="text-silver">Ciência da Computação</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-icon text-infect">🌐</span>
                                    <a href="https://github.com/Bilissom" target="_blank" class="text-soul">github.com/Bilissom</a>
                                </div>
                            </div>

                            <div class="social-links">
                                <a href="https://github.com/Bilissom" target="_blank" class="social-btn" id="about-github">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                                    GitHub
                                </a>
                                <a href="mailto:alissoncaiosilvasilveira70@gmail.com" class="social-btn essence" id="about-email">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                    Email
                                </a>
                            </div>
                        </div>


                        <div class="about-right">
                            <div class="bio-scroll gothic-card" id="about-bio">
                                <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                <div class="card-corner bl"></div><div class="card-corner br"></div>
                                <div class="scroll-ornament">❦</div>
                                <p>
                                    Olá! Sou <strong class="text-pale">Alisson Caio</strong>, desenvolvedor front-end apaixonado por
                                    criar interfaces bonitas e funcionais. Assim como o Knight desbrava os mistérios de Hallownest,
                                    eu exploro as profundezas do desenvolvimento web com curiosidade e determinação.
                                </p>
                                <br />
                                <p>
                                    Tenho experiência com tecnologias modernas como <span class="text-soul">React</span>,
                                    <span class="text-essence">Blazor</span>, <span class="text-geo">CSS avançado</span> e
                                    JavaScript. Gosto de transformar designs em experiências interativas que encantam os usuários.
                                </p>
                                <br />
                                <p>
                                    Quando não estou codando, estou explorando novos jogos, aprendendo sobre design de UX
                                    ou contribuindo para projetos open source.
                                </p>
                                <div class="scroll-ornament bottom">❦</div>
                            </div>

                            <div class="timeline-section" id="about-timeline">
                                <h3 class="text-pale mb-lg">⏳ Jornada em Hallownest</h3>
                                @foreach (var item in Timeline)
                                {
                                    <div class="timeline-item" id="timeline-@item.Id">
                                        <div class="timeline-marker">
                                            <div class="marker-dot"></div>
                                            <div class="marker-line"></div>
                                        </div>
                                        <div class="timeline-content gothic-card">
                                            <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                            <div class="timeline-year text-soul">@item.Year</div>
                                            <h4 class="timeline-title text-pale">@item.Title</h4>
                                            <p class="timeline-desc text-silver">@item.Description</p>
                                            <div class="timeline-tags">
                                                @foreach (var tag in item.Tags)
                                                {
                                                    <span class="tag-pill soul">@tag</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            else if (activePage == "Skills")
            {
                <div class="page-container">
                    <div class="section-header">
                        <h1 class="text-pale">Arsenal de Charms</h1>
                        <div class="section-divider">
                            <span class="section-subtitle">habilidades &amp; tecnologias</span>
                        </div>
                        <p class="text-silver text-center" style="max-width:600px; margin: 1rem auto 0; font-size:1.05rem; font-style:italic">
                            Como o Knight coleta charms pelo reino de Hallownest, eu acumulo habilidades
                            que fortalecem cada projeto que construo.
                        </p>
                    </div>

                    <div class="category-filter" id="skills-filter">
                        @foreach (var cat in Categories)
                        {
                            <button
                                class="filter-btn @(activeCategory == cat ? "active" : "")"
                                id="filter-@cat.ToLower().Replace(" ", "-")"
                                @onclick="() => activeCategory = cat">
                                @cat
                            </button>
                        }
                    </div>

                    <div class="skills-grid" id="skills-grid">
                        @foreach (var skill in FilteredSkills)
                        {
                            <div class="charm-card gothic-card" id="charm-card-@skill.Id">
                                <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                <div class="card-corner bl"></div><div class="card-corner br"></div>

                                <span class="charm-icon-lg" style="color: @skill.Color; filter: drop-shadow(0 0 12px @skill.Color)">@skill.Icon</span>

                                <div class="charm-notch">
                                    <div class="notch-glow" style="background: @skill.Color"></div>
                                </div>

                                <h3 class="charm-name text-pale">@skill.Name</h3>

                                <div class="skill-bar-container">
                                    <div class="skill-bar">
                                        <div class="skill-bar-fill"
                                             style="width: @(skill.Level * 20)%; background: linear-gradient(to right, @skill.Color, @skill.ColorLight)">
                                        </div>
                                    </div>
                                    <span class="skill-percent text-silver">@(skill.Level * 20)%</span>
                                </div>

                                <div class="skill-tags">
                                    <span class="tag-pill @skill.TagType">@skill.Category</span>
                                </div>

                                <div class="equip-text text-soul">✦ Equipado</div>
                            </div>
                        }
                    </div>

                    <div class="lore-divider">
                        <div class="lore-line"></div>
                        <div class="lore-icon text-essence">⚔</div>
                        <div class="lore-line"></div>
                    </div>

                    <section class="tools-section" id="tools-section">
                        <div class="section-header">
                            <h2 class="text-pale">Relíquias &amp; Ferramentas</h2>
                        </div>
                        <div class="tools-grid">
                            @foreach (var tool in Tools)
                            {
                                <div class="tool-item gothic-card" id="tool-@tool.Id">
                                    <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                    <div class="card-corner bl"></div><div class="card-corner br"></div>
                                    <span class="tool-icon">@tool.Icon</span>
                                    <span class="tool-name text-silver">@tool.Name</span>
                                </div>
                            }
                        </div>
                    </section>
                </div>
            }

            else if (activePage == "Projects")
            {
                <div class="page-container">
                    <div class="section-header">
                        <h1 class="text-pale">Mapa de Hallownest</h1>
                        <div class="section-divider">
                            <span class="section-subtitle">projetos &amp; explorações</span>
                        </div>
                        <p class="text-silver text-center" style="max-width:600px; margin: 1rem auto 0; font-size:1.05rem; font-style:italic">
                            Cada projeto é uma área do mapa desbravada — com seus próprios desafios,
                            criaturas e segredos a descobrir.
                        </p>
                    </div>

                    <div class="tag-filter" id="projects-filter">
                        @foreach (var tag in FilterTags)
                        {
                            <button
                                class="filter-btn @(activeFilter == tag ? "active" : "")"
                                id="filter-@tag.ToLower().Replace("#","-")"
                                @onclick="() => activeFilter = tag">
                                @tag
                            </button>
                        }
                    </div>

                    <div class="projects-grid" id="projects-grid">
                        @foreach (var proj in FilteredProjects)
                        {
                            <article class="project-card gothic-card @(proj.Featured ? "featured" : "")"
                                     id="project-@proj.Id">
                                <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                <div class="card-corner bl"></div><div class="card-corner br"></div>

                                @if (proj.Featured)
                                {
                                    <div class="featured-badge">
                                        <span class="text-geo">◆</span>
                                        <span>Destaque</span>
                                    </div>
                                }

                                <div class="project-header">
                                    <div class="project-icon" style="color: @proj.Color">@proj.Icon</div>
                                    <div class="project-meta">
                                        <span class="project-area text-silver">@proj.Area</span>
                                        <h3 class="project-title text-pale">@proj.Title</h3>
                                    </div>
                                </div>

                                <p class="project-desc text-silver">@proj.Description</p>

                                <div class="project-tags">
                                    @foreach (var tag in proj.Tags)
                                    {
                                        <span class="tag-pill soul">@tag</span>
                                    }
                                </div>

                                <div class="project-links">
                                    @if (!string.IsNullOrEmpty(proj.GitHub))
                                    {
                                        <a href="@proj.GitHub" target="_blank" class="project-link" id="proj-github-@proj.Id">
                                            <span>⚡</span> Código
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(proj.Demo))
                                    {
                                        <a href="@proj.Demo" target="_blank" class="project-link demo" id="proj-demo-@proj.Id">
                                            <span>🔮</span> Demo
                                        </a>
                                    }
                                </div>

                                <div class="map-stamp" style="color: @proj.Color">@proj.Icon</div>
                            </article>
                        }
                    </div>

                    @if (!FilteredProjects.Any())
                    {
                        <div class="no-results text-center">
                            <div style="font-size: 3rem; margin-bottom: 1rem">🗺️</div>
                            <p class="text-silver">Nenhum projeto encontrado nessa área do mapa.</p>
                        </div>
                    }
                </div>
            }

            else if (activePage == "Contact")
            {
                <div class="page-container">
                    <div class="section-header">
                        <h1 class="text-pale">Invocar o Espírito</h1>
                        <div class="section-divider">
                            <span class="section-subtitle">entre em contato</span>
                        </div>
                    </div>

                    <div class="contact-grid">

                        <div class="npc-dialog-section" id="contact-npc">
                            <div class="npc-container">
                                <div class="npc-character">
                                    <div class="npc-avatar">
                                        <img src="images/knight.png" alt="The Knight" class="skull-img" />
                                        <div class="skull-glow"></div>
                                    </div>
                                    <div class="npc-name text-soul">Alisson Caio</div>
                                    <div class="npc-title text-silver">Desenvolvedor Front-End</div>
                                </div>

                                <div class="dialog-box gothic-card" id="contact-dialog-box">
                                    <div class="card-corner tl"></div><div class="card-corner tr"></div>
                                    <div class="card-corner bl"></div><div class="card-corner br"></div>
                                    <p class="dialog-text">
                                        <span class="dialog-cursor text-soul">▶</span>
                                        @dialogText
                                    </p>
                                </div>

                                <div class="dialog-options" id="contact-dialog-options">
                                    @foreach (var opt in DialogOptions)
                                    {
                                        <button
                                            class="dialog-option @(activeDialog == opt.Id ? "selected" : "")"
                                            id="dialog-opt-@opt.Id"
                                            @onclick="() => SelectDialog(opt)">
                                            <span class="option-arrow">›</span>
                                            @opt.Label
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="contact-links" id="contact-links">
                                <a href="mailto:alissoncaiosilvasilveira70@gmail.com" class="contact-link-item" id="contact-email">
                                    <div class="link-icon text-soul">
