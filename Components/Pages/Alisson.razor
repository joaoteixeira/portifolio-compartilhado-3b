    protected override void OnInitialized()
    {
        var rng   = new Random();
        var types = new[] { "soul", "soul", "soul", "essence", "geo" };

        for (int i = 0; i < 40; i++)
        {
            particles.Add(new Particle
            {
                X        = rng.NextDouble() * 100,
                Size     = rng.NextDouble() * 4 + 2,
                Duration = rng.NextDouble() * 15 + 10,
                Delay    = rng.NextDouble() * -30,
                Drift    = (rng.NextDouble() - 0.5) * 80,
                Type     = types[rng.Next(types.Length)]
            });
        }
    }

    private class Particle
