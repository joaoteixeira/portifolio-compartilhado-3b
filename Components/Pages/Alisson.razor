@page "/Alisson"

<PageTitle>Alisson Caio</PageTitle>

<!-- Container principal que ocupa a tela e centraliza o cartão usando Flexbox -->
<div class="alisson-container">
    
    <!-- O cartão principal onde aplicamos o efeito Glassmorphism (vidro fosco) -->
    <div class="profile-card">
        
        <!-- Cabeçalho do cartão contendo a foto de perfil (avatar) -->
        <div class="card-header">
            <div class="avatar">AC</div>
        </div>
        
        <!-- Corpo do cartão com as informações principais -->
        <div class="card-body">
            <!-- Nome da pessoa com efeito de texto em gradiente -->
            <h1 class="name">Alisson Caio</h1>
            <!-- Cargo ou papel atual -->
            <p class="role">Desenvolvedor & Estudante</p>
            
            <!-- Breve biografia ou descrição -->
            <p class="bio">
                Apaixonado por tecnologia e desenvolvimento de software. 
                Sempre em busca de novos desafios, aprendizados e de deixar minha marca no mundo da programação!
            </p>

            <!-- Seção de habilidades representadas como tags -->
            <div class="skills">
                <span class="skill-tag">C#</span>
                <span class="skill-tag">.NET</span>
                <span class="skill-tag">Blazor</span>
                <span class="skill-tag">HTML/CSS</span>
                <span class="skill-tag">JavaScript</span>
            </div>

            <!-- Botões de ação (ex: Contato, Projetos) -->
            <div class="actions">
                <button class="btn primary">Entrar em Contato</button>
                <button class="btn secondary">Ver Projetos</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos do container principal. O background é um gradiente escuro e elegante. */
    .alisson-container {
        font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        min-height: 80vh; /* Ocupa no mínimo 80% da altura da tela */
        display: flex;
        align-items: center; /* Centraliza verticalmente */
        justify-content: center; /* Centraliza horizontalmente */
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        padding: 2rem;
        border-radius: 16px;
        color: #ffffff;
        margin-top: 1rem;
    }

    /* Estilo principal do Glassmorphism. Fundo semi-transparente e desfoque no fundo (backdrop-filter) */
    .profile-card {
        background: rgba(255, 255, 255, 0.05); /* Fundo branco com 5% de opacidade */
        backdrop-filter: blur(10px); /* Efeito de desfoque no fundo (vidro) */
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1); /* Borda sutil para destacar o vidro */
        border-radius: 20px;
        padding: 2.5rem;
        max-width: 450px;
        width: 100%;
        text-align: center;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37); /* Sombra para dar profundidade */
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
    }

    /* Animação ao passar o mouse por cima do cartão inteiro */
    .profile-card:hover {
        transform: translateY(-10px); /* Faz o cartão "flutuar" para cima */
        box-shadow: 0 15px 45px 0 rgba(0, 0, 0, 0.5); /* Aumenta a sombra */
    }

    .card-header {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    /* Estilização do avatar (iniciais com gradiente e borda) */
    .avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(45deg, #ff00cc, #333399); /* Fundo em gradiente rosa/roxo */
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: bold;
        color: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        border: 4px solid rgba(255,255,255,0.2);
        transition: transform 0.3s ease;
    }
    
    /* Efeito de rotação e aumento no avatar quando o mouse passa sobre o cartão */
    .profile-card:hover .avatar {
        transform: scale(1.05) rotate(5deg);
    }

    /* Nome com gradiente aplicado apenas no texto (efeito bem moderno) */
    .name {
        font-size: 2.2rem;
        margin: 0;
        font-weight: 700;
        background: -webkit-linear-gradient(#fff, #d1d5db);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* O Cargo (role) ganha uma cor mais suave e letras maiúsculas espaçadas */
    .role {
        color: #9ca3af;
        font-size: 1rem;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    /* Texto comum do sobre mim */
    .bio {
        font-size: 1rem;
        line-height: 1.6;
        color: #d1d5db;
        margin-bottom: 2rem;
    }

    /* Layout flexível para as skills se ajustarem na linha */
    .skills {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem;
        margin-bottom: 2rem;
    }

    /* Cada etiqueta de habilidade é arredondada e tem fundo transparente */
    .skill-tag {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
        cursor: default;
    }

    /* Animação de pulo nas tags de habilidades quando o mouse passa nelas */
    .skill-tag:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: translateY(-3px);
        color: #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    /* Alinhamento dos botões no rodapé */
    .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    /* Estilo base compartilhado pelos botões */
    .btn {
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
        outline: none;
    }

    /* Botão Principal: Cores sólidas em gradiente (igual ao avatar) */
    .btn.primary {
        background: linear-gradient(45deg, #ff00cc, #333399);
        color: white;
        box-shadow: 0 4px 15px rgba(255, 0, 204, 0.3);
    }

    /* Levanta levemente o botão e aumenta o brilho no hover */
    .btn.primary:hover {
        box-shadow: 0 6px 20px rgba(255, 0, 204, 0.5);
        transform: translateY(-2px);
    }

    /* Botão Secundário: Estilo contorno (Ghost Button) */
    .btn.secondary {
        background: transparent;
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.3);
    }

    /* Preenche sutilmente o fundo no hover */
    .btn.secondary:hover {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.6);
        transform: translateY(-2px);
    }
</style>