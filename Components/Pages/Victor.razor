@page "/victor"

<div class="container mt-4">
    <div class="card shadow p-4">

        <div class="text-center">
            <img src="images/victor.jpg"
                 alt="Foto de Victor Henrique Ferreira Cardoso"
                 class="rounded-circle mb-3"
                 style="width: 180px; height: 180px; object-fit: cover;" />

            <h1>Victor Henrique Ferreira Cardoso</h1>
            <h4 class="text-secondary">Aluno - 3º B Informática</h4>
        </div>

        <hr />

        <h3>Sobre Mim</h3>
        <p>
            Olá! Meu nome é <strong>Victor Henrique Ferreira Cardoso</strong>,
            sou aluno do <strong>3º B de Informática</strong> e tenho interesse
            em desenvolvimento de sistemas, programação e tecnologia.
        </p>

        <h3>Projetos Desenvolvidos</h3>

        <div class="row">

            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">AgroNexis</h5>
                        <p class="card-text">
                            Sistema voltado para o setor agropecuário,
                            auxiliando no gerenciamento e organização de informações.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">SIGHA</h5>
                        <p class="card-text">
                            Projeto desenvolvido para facilitar o controle,
                            gerenciamento e consulta de dados de forma eficiente.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">SIGEA</h5>
                        <p class="card-text">
                            Sistema criado para otimizar processos administrativos
                            e melhorar a organização das informações.
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <hr />

        <h3>Habilidades</h3>
        <ul>
            <li>C#</li>
            <li>Blazor</li>
            <li>HTML e CSS</li>
            <li>Banco de Dados</li>
            <li>Desenvolvimento Web</li>
        </ul>

    </div>
</div>