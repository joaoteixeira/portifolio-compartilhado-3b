@page "/gustavo"

<div class="container">

    <div class="perfil">
        <h1>👨‍💻 Gustavo Moreira</h1>
        <p>Estudante de Desenvolvimento de Sistemas</p>
    </div>

    <div class="cards">

        <div class="card">
            <h3>🎓 Sobre Mim</h3>
            <p>
                Sou estudante de Desenvolvimento de Sistemas e gosto de aprender
                novas tecnologias relacionadas à programação e desenvolvimento web.
            </p>
        </div>

        <div class="card">
            <h3>💻 Tecnologias</h3>
            <ul>
                <li>HTML</li>
                <li>CSS</li>
                <li>JavaScript</li>
                <li>C#</li>
                <li>SQL</li>
            </ul>
        </div>

        <div class="card">
            <h3>🚀 Objetivos</h3>
            <p>
                Aprimorar minhas habilidades como desenvolvedor e criar sistemas
                modernos e funcionais.
            </p>
        </div>

        <div class="card">
            <h3>📚 Interesses</h3>
            <p>
                Desenvolvimento Web, Banco de Dados, Programação e Tecnologia.
            </p>
        </div>

    </div>

</div>

<style>

    .container {
        min-height: 100vh;
        background-color: #121212;
        color: #ffffff;
        padding: 30px;
        font-family: Arial, sans-serif;
    }

    .perfil {
        text-align: center;
        margin-bottom: 30px;
    }

    .perfil h1 {
        color: #7c5cff;
        margin-bottom: 10px;
    }

    .perfil p {
        color: #b0b0b0;
    }

    .cards {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
    }

    .card {
        background-color: #1e1e1e;
        width: 280px;
        padding: 20px;
        border-radius: 10px;
        border: 1px solid #333;
        transition: 0.3s;
    }

    .card:hover {
        transform: translateY(-5px);
        border-color: #7c5cff;
    }

    .card h3 {
        color: #7c5cff;
        margin-bottom: 10px;
    }

    .card ul {
        padding-left: 20px;
    }

</style>

